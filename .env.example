# NEXT_PUBLIC_SITE_URL=https://productbase-jp.com
# NEXT_PUBLIC_AUTH_CALLBACK_URL=https://productbase-jp.com/auth/callback

# Google OAuth（任意）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Stripe（任意）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
